# Timezone for all containers
TZ=America/Vancouver

# OAuth credentials for Claude.ai MCP connector
# Generate your own:
#   openssl rand -hex 16   → OAUTH_CLIENT_ID
#   openssl rand -hex 32   → OAUTH_CLIENT_SECRET
OAUTH_CLIENT_ID=your-oauth-client-id-here
OAUTH_CLIENT_SECRET=your-oauth-client-secret-here

# Cloudflare Tunnel token
# Create a tunnel at https://one.dash.cloudflare.com → Networks → Tunnels
# Point it at http://mcp-netflow:3000
TUNNEL_TOKEN=your-cloudflare-tunnel-token-here

# MaxMind GeoLite2 credentials (free account)
# Sign up at https://www.maxmind.com/en/geolite2/signup
GEOIPUPDATE_ACCOUNT_ID=your-maxmind-account-id
GEOIPUPDATE_LICENSE_KEY=your-maxmind-license-key
